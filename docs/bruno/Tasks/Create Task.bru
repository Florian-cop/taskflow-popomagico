meta {
  name: Create Task
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/projects/{{projectId}}/tasks
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "title": "Première tâche",
    "description": "Description de la tâche"
  }
}

script:post-response {
  if (res.status === 201 && res.body && res.body.id) {
    bru.setEnvVar("taskId", res.body.id);
  }
}
